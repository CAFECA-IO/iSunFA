    "@prisma/client": "^7.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "dotenv": "^17.2.3",
    "dotenv-expand": "^12.0.3",
    "html-to-image": "^1.11.13",
    "jest": "^30.3.0",
