generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id               String   @id @default(uuid())
  identityAddress  String?  @map("identity_address") // Info: (20260112 - Tzuhan) RWA Identity Contract (ONCHAINID)
  address          String   @unique //  Info: (20260112 - Tzuhan) 用戶的錢包 (address) 是這個 RWA Identity Contract 合約的 Owner
  pubKeyX          String?  @map("pub_key_x")
  pubKeyY          String?  @map("pub_key_y")
  credentialId     String?  @unique @map("credential_id")
  currentChallenge String?  @map("current_challenge")
  name             String?
  imageUrl         String?  @map("image_url")
  kycData          Json?    @map("kyc_data")
  role             Role     @default(USER)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orders           Order[]
  analyses         Analysis[]
  missions         Mission[]

  @@map("user")
  @@index([address])
}

model Order {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  type        String
  amount      Int
  data        Json
  status      String   @default("PENDING")
  challenge   String
  signature   String?
  transactionHash String? @map("transaction_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  analysis    Analysis[]

  @@map("order")
}

// Info: (20260128 - Luphia) Analysis 直接將 data 與 result 放在 mission 裡面
model Analysis {
  id          String   @id
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  orderId     String   @map("order_id")
  order       Order    @relation(fields: [orderId], references: [id])
  type        String
  data        Json
  result      Json?
  missionId   String?  @map("mission_id")
  mission     Mission? @relation(fields: [missionId], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("analysis")
}

model Mission {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  name        String
  status      String   @default("PENDING") // Info: (20260128 - Luphia) PENDING, RUNNING, COMPLETED, FAILED
  tasks       Task[]
  analyses    Analysis[]
  data        Json?
  result      Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("mission")
}

model Task {
  id          String   @id @default(uuid())
  missionId   String   @map("mission_id")
  mission     Mission  @relation(fields: [missionId], references: [id])
  type        String
  status      String   @default("PENDING") // Info: (20260128 - Luphia) PENDING, RUNNING, COMPLETED, FAILED
  order       Int      @default(0) // Info: (20260128 - Luphia) Execution order. Equal values = parallel
  data        Json?
  result      Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("task")
}
