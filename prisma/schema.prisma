generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id String @id @default(uuid())

  // Info: (20260112 - Tzuhan) RWA Identity Contract (ONCHAINID)
  identityAddress String? @map("identity_address")

  //  Info: (20260112 - Tzuhan) 用戶的錢包 (address) 是這個 RWA Identity Contract 合約的 Owner
  address          String   @unique
  pubKeyX          String?  @map("pub_key_x")
  pubKeyY          String?  @map("pub_key_y")
  credentialId     String?  @unique @map("credential_id")
  currentChallenge String?  @map("current_challenge")
  name             String?
  imageUrl         String?  @map("image_url")
  kycData          Json?    @map("kyc_data")
  role             Role     @default(USER)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orders              Order[]
  analyses            Analysis[]
  missions            Mission[]
  threads             Thread[]
  comments            Comment[]
  receivedReplies     Comment[]            @relation("CommentRecipient")
  reactions           Reaction[]
  paymentMethods      PaymentMethod[]
  paymentTransactions PaymentTransaction[]
  journals            Journal[]
  teamMembers         TeamMember[]
  auditLogs           AuditLog[]
  vouchers            Voucher[]

  @@index([address])
  @@map("user")
}

model Team {
  id           String        @id @default(uuid())
  name         String
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  deletedAt    DateTime?     @map("deleted_at")
  teamMembers  TeamMember[]
  accountBooks AccountBook[]

  @@map("team")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  team      Team     @relation(fields: [teamId], references: [id])
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  role      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_member")
}

model Order {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  type            String
  amount          Int
  data            Json
  status          String   @default("PENDING")
  challenge       String
  signature       String?
  transactionHash String?  @map("transaction_hash")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  analysis            Analysis[]
  paymentTransactions PaymentTransaction[]
  receipt             Receipt?

  @@map("order")
}

// Info: (20260128 - Luphia) Analysis 直接將 data 與 result 放在 mission 裡面
model Analysis {
  id        String   @id
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id])
  type      String
  data      Json
  result    Json?
  missionId String?  @map("mission_id")
  mission   Mission? @relation(fields: [missionId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("analysis")
}

model Mission {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  name   String

  // Info: (20260128 - Luphia) PENDING, RUNNING, COMPLETED, FAILED
  status    String     @default("PENDING")
  tasks     Task[]
  analyses  Analysis[]
  data      Json?
  result    Json?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("mission")
}

model Task {
  id        String  @id @default(uuid())
  missionId String  @map("mission_id")
  mission   Mission @relation(fields: [missionId], references: [id])
  type      String

  // Info: (20260128 - Luphia) PENDING, RUNNING, COMPLETED, FAILED
  status String @default("PENDING")

  // Info: (20260128 - Luphia) Execution order. Equal values = parallel
  order     Int      @default(0)
  data      Json?
  result    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("task")
}

// Info: (20260211 - Julian) AI Consultation Room 討論串
model Thread {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id])
  question  String      @db.Text
  answer    String?     @db.Text
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  files     File[]
  comments  Comment[]
  reactions Reaction[]
  tags      ThreadTag[]
  shares    Share[]

  @@map("thread")
}

// Info: (20260226 - Julian) 上傳檔案：儲存 hash
model File {
  id       String  @id @default(uuid())
  hash     String
  fileName String? @map("file_name")

  thread   Thread? @relation(fields: [threadId], references: [id])
  threadId String? @map("thread_id")

  journals Journal[]
  vouchers Voucher[]

  @@map("file")
}

// Info: (20260212 - Julian) 評論：支援巢狀回覆
model Comment {
  id       String @id @default(uuid())
  content  String @db.Text
  userId   String @map("user_id")
  user     User   @relation(fields: [userId], references: [id])
  threadId String @map("thread_id")
  thread   Thread @relation(fields: [threadId], references: [id])

  // Info: (20260212 - Julian) 巢狀邏輯
  parentCommentId String?   @map("parent_comment_id")
  parentComment   Comment?  @relation("ReplyTo", fields: [parentCommentId], references: [id])
  replies         Comment[] @relation("ReplyTo")

  // Info: (20260212 - Julian) 回覆對象
  replyToUserId String? @map("reply_to_user_id")
  replyToUser   User?   @relation("CommentRecipient", fields: [replyToUserId], references: [id])

  createdAt      DateTime   @default(now()) @map("created_at")
  deletedAt      DateTime?  @map("deleted_at")
  isProfessional Boolean    @default(false) @map("is_professional")
  reactions      Reaction[]

  @@map("comment")
}

// Info: (20260212 - Julian) 討論串標籤
model Tag {
  id      String      @id @default(uuid())
  name    String      @unique
  threads ThreadTag[]

  @@map("tag")
}

enum ReactionType {
  LIKE
  DISLIKE
}

// Info: (20260212 - Julian) 討論串的按讚
model Reaction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  // Info: (20260212 - Julian) 評價類型：是讚還是倒讚
  type ReactionType

  // Info: (20260212 - Julian) 關聯使用者
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  // Info: (20260212 - Julian) 關聯討論串
  threadId String? @map("thread_id")
  thread   Thread? @relation(fields: [threadId], references: [id])

  // Info: (20260212 - Julian) 關聯評論
  commentId String?  @map("comment_id")
  comment   Comment? @relation(fields: [commentId], references: [id])

  // Info: (20260212 - Julian) 核心約束：一個使用者對同一個物件只能有一個評價
  @@unique([userId, threadId])
  @@unique([userId, commentId])
  @@map("reaction")
}

// Info: (20260212 - Julian) 討論串的分享紀錄
model Share {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  // Info: (20260212 - Julian) 關聯討論串
  threadId String @map("thread_id")
  thread   Thread @relation(fields: [threadId], references: [id])

  @@map("share")
}

// Info: (20260212 - Julian) Threads - Tags
model ThreadTag {
  threadId  String   @map("thread_id")
  thread    Thread   @relation(fields: [threadId], references: [id])
  tagId     String   @map("tag_id")
  tag       Tag      @relation(fields: [tagId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Info: (20260212 - Julian) 討論串和標籤是多對多的關係
  @@id([threadId, tagId])
  @@map("thread_tag")
}

model PaymentMethod {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  provider  String
  token     String
  data      Json?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions PaymentTransaction[]

  @@map("payment_method")
}

// Info: (20260302 - Tzuhan) 獨立的 PaymentTransaction Table，減少支付模組的耦合性
model PaymentTransaction {
  id              String         @id @default(uuid())
  userId          String         @map("user_id")
  user            User           @relation(fields: [userId], references: [id])
  paymentMethodId String?        @map("payment_method_id")
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  orderId         String?        @map("order_id")
  order           Order?         @relation(fields: [orderId], references: [id])
  provider        String
  amount          Int
  status          String         @default("PENDING") // Info: (20260302 - Tzuhan) PENDING, SUCCESS, FAILED
  errorMessage    String?        @map("error_message")
  rawData         Json?          @map("raw_data")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@map("payment_transaction")
}

model Receipt {
  id        String   @id @default(uuid())
  orderId   String   @unique @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id])
  amount    Int
  data      Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("receipt")
}

// Info: (20260304 - Julian) 憑證/日記帳
model Journal {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  text      String   @db.Text // Info: (20260304 - Julian) AI 辨識出的文字結果

  fileId String @map("file_id")
  file   File   @relation(fields: [fileId], references: [id])

  // Info: (20260305 - Julian) 隸屬的帳本
  accountBookId String      @map("account_book_id")
  accountBook   AccountBook @relation(fields: [accountBookId], references: [id])
  user          User?       @relation(fields: [userId], references: [id])
  userId        String?

  @@map("journal")
}

// Info: (20260305 - Julian) 帳本
model AccountBook {
  id        String    @id @default(uuid())
  name      String
  country   String
  currency  String
  rule      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Info: (20260306 - Luphia) 帳本所屬的團隊
  teamId String @map("team_id")
  team   Team   @relation(fields: [teamId], references: [id])

  // Info: (20260305 - Julian) 一個帳本可以有多個憑證
  journals Journal[]

  // Info: (20260310 - Julian) 一個帳本可以有多個傳票
  vouchers Voucher[]

  // Info: (20260306 - Julian) 一個帳本可以有多個編輯紀錄
  auditLogs AuditLog[]

  @@map("account_book")
}

// Info: (20260306 - Julian) 資料編輯 log
enum AuditLogDataType {
  JOURNAL
  VOUCHER
  CARBON
}

enum AuditLogAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  // Info: (20260306 - Julian) 編輯的資料類型 journal / voucher / carbon
  dataType AuditLogDataType @map("data_type")
  // Info: (20260306 - Julian) 編輯的資料 journalId / voucherId / carbonId
  dataId   String           @map("data_id")

  // Info: (20260306 - Julian) 編輯資料所屬的帳本
  accountBookId String      @map("account_book_id")
  accountBook   AccountBook @relation(fields: [accountBookId], references: [id])

  // Info: (20260306 - Julian) 編輯的動作 建立 / 更新 / 刪除
  action AuditLogAction @map("action")

  // Info: (20260306 - Julian) 編輯者的使用者
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

// Info: (20260310 - Julian) 傳票
model Voucher {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Info: (20260310 - Julian) 交易日期
  tradingDate DateTime @map("trading_date")

  // Info: (20260310 - Julian) 交易類別: income, outcome, transfer
  tradingType String   @map("trading_type")

  // Info: (20260310 - Julian) 備註
  note        String   @db.Text

  // Info: (20260310 - Julian) 開立人名稱
  issuerName  String   @map("issuer_name")

  // Info: (20260310 - Julian) 幣別
  currency    String   @default("TWD")

  // Info: (20260310 - Julian) 關聯檔案 (如附件)
  fileId String? @map("file_id")
  file   File?   @relation(fields: [fileId], references: [id])

  // Info: (20260310 - Julian) 隸屬的帳本
  accountBookId String      @map("account_book_id")
  accountBook   AccountBook @relation(fields: [accountBookId], references: [id])

  // Info: (20260310 - Julian) 建立此傳票的 User
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  // 包含的分錄
  lines VoucherLine[]

  @@map("voucher")
}

// Info: (20260310 - Julian) 傳票分錄
model VoucherLine {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Info: (20260310 - Julian) 隸屬的傳票
  voucherId String  @map("voucher_id")
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  // Info: (20260310 - Julian) 會計項目 (前端使用 IAccount)

  // Info: (20260310 - Julian) 科目代碼
  accountingCode String @map("accounting_code")

  // Info: (20260310 - Julian) 科目名稱
  accountingName String @map("accounting_name")

  // Info: (20260310 - Julian) 摘要
  particular String @db.Text

  // Info: (20260310 - Julian) 金額
  amount Int

  // Info: (20260310 - Julian) 是否為借方 (true=借方/Debit, false=貸方/Credit)
  isDebit Boolean @map("is_debit")

  @@map("voucher_line")
}
